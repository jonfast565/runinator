{
  "namespace": "runinator",
  "jobs": [
    {
      "name": "claude",
      "source": {
        "type": "command",
        "run": ["keychain-export", "--service", "Claude Code-credentials", "--quiet"]
      },
      "sinks": [
        { "type": "kube-secret", "name": "claude-credentials", "key": ".credentials.json" },
        { "type": "file", "path": "~/.claude/.credentials.json" }
      ]
    },
    {
      "name": "aws-sso",
      "refresh": {
        "unless": ["aws", "sts", "get-caller-identity", "--profile", "runinator", "--no-cli-pager"],
        "run": ["aws", "sso", "login", "--profile", "runinator"]
      },
      "source": { "type": "dir", "path": "~/.aws/sso/cache", "glob": "*.json" },
      "sinks": [
        { "type": "kube-secret", "name": "aws-sso-cache" }
      ]
    },
    {
      "name": "github-token",
      "source": { "type": "command", "run": ["gh", "auth", "token"] },
      "sinks": [
        { "type": "kube-secret", "name": "github-token", "key": "token" }
      ]
    },
    {
      "name": "slack-token",
      "source": { "type": "command", "run": ["keychain-export", "--service", "slack-token", "--quiet"] },
      "sinks": [
        { "type": "kube-secret", "name": "slack-token", "key": "token" }
      ]
    }
  ]
}

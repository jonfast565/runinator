{
  "namespace": "runinator",
  "jobs": [
    {
      "name": "aws-sso",
      "refresh": {
        "unless": ["aws", "sts", "get-caller-identity", "--profile", "default", "--no-cli-pager"],
        "run": ["aws", "sso", "login", "--profile", "default"]
      },
      "source": { "type": "dir", "path": "~/.aws/sso/cache", "glob": "*.json" },
      "sinks": [
        { "type": "kube-secret", "name": "aws-sso-cache" }
      ]
    }
  ]
}

  "workflows": [
    {
      "id": 1001,
      "name": "Mock SDLC: Feature Delivery",
      "version": 1,
      "enabled": true,
      "input_schema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "ticket": { "type": "string" },
          "operator": { "type": "string" }
        }
      },
      "definition": {
        "start": "intake_ticket",
        "concurrency": 1,
        "metadata": {
          "domain": "mock-sdlc",
          "description": "A local end-to-end SDLC workflow for command-center testing."
        },
        "nodes": [
          {
            "id": "intake_ticket",
            "kind": "task",
            "task_id": 101,
            "parameters": {
              "command": "echo '[mock-sdlc] intake accepted ticket RUN-101 for local workflow test'"
            },
            "transitions": { "on_success": { "$node": "create_branch" } }
          },
          {
            "id": "create_branch",
            "kind": "task",
            "task_id": 102,
            "parameters": {
              "command": "echo '[mock-sdlc] branch feature/mock-sdlc-run created'"
            },
            "transitions": { "on_success": { "$node": "implement_change" } }
          },
          {
            "id": "implement_change",
            "kind": "task",
            "task_id": 103,
            "parameters": {
              "command": "echo '[mock-sdlc] feature implemented with tests and release notes'"
            },
            "transitions": { "on_success": { "$node": "run_unit_tests" } }
          },
          {
            "id": "run_unit_tests",
            "kind": "task",
            "task_id": 104,
            "parameters": {
              "command": "echo '[mock-sdlc] cargo test passed for feature branch'"
            },
            "transitions": { "on_success": { "$node": "tests_passed" } },
            "retry": { "max_attempts": 2 },
            "timeout_seconds": 30
          },
          {
            "id": "tests_passed",
            "kind": "condition",
            "condition": {
              "value": { "$ref": { "node": "run_unit_tests", "output": ["success"] } },
              "equals": true
            },
            "transitions": {
              "on_success": { "$node": "review_approval" }
            }
          },
          {
            "id": "review_approval",
            "kind": "approval",
            "parameters": {
              "approval_type": "code_review",
              "prompt": "Approve the mock pull request for QA."
            },
            "transitions": {
              "on_success": { "$node": "qa_verification" }
            }
          },
          {
            "id": "qa_verification",
            "kind": "task",
            "task_id": 105,
            "parameters": {
              "command": "echo '[mock-sdlc] qa verification completed against staging build'"
            },
            "transitions": { "on_success": { "$node": "release_gate" } }
          },
          {
            "id": "release_gate",
            "kind": "approval",
            "parameters": {
              "approval_type": "release",
              "prompt": "Approve staging deployment for the mock SDLC workflow."
            },
            "transitions": {
              "on_success": { "$node": "deploy_release" }
            }
          },
          {
            "id": "deploy_release",
            "kind": "task",
            "task_id": 106,
            "parameters": {
              "command": "echo '[mock-sdlc] release deployed and ticket moved to Done'"
            },
            "transitions": { "on_success": { "$node": "done" } }
          },
          {
            "id": "done",
            "kind": "end"
          }
        ],
        "ui": {
          "layout": {
            "intake_ticket": { "x": 0, "y": 0 },
            "create_branch": { "x": 230, "y": 0 },
            "implement_change": { "x": 460, "y": 0 },
            "run_unit_tests": { "x": 690, "y": 0 },
            "tests_passed": { "x": 920, "y": 0 },
            "review_approval": { "x": 1150, "y": 0 },
            "qa_verification": { "x": 1380, "y": 0 },
            "release_gate": { "x": 1610, "y": 0 },
            "deploy_release": { "x": 1840, "y": 0 },
            "done": { "x": 2070, "y": 0 }
          }
        }
      }
    },
    {
      "id": 1003,
      "name": "SDLC: Implement, Review, QA Until Done",
      "version": 1,
      "enabled": true,
      "input_schema": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "jira_base_url",
          "jira_token",
          "jira_jql",
          "jira_done_transition_id",
          "jira_rework_transition_id",
          "git_repo",
          "workspace_root",
          "implementation_command",
          "github_token",
          "github_owner",
          "github_repo"
        ],
        "properties": {
          "jira_base_url": { "type": "string" },
          "jira_token": { "type": "string" },
          "jira_email": { "type": "string" },
          "jira_jql": { "type": "string" },
          "jira_done_transition_id": { "type": "string" },
          "jira_rework_transition_id": { "type": "string" },
          "git_repo": { "type": "string" },
          "workspace_root": { "type": "string" },
          "implementation_command": { "type": "string" },
          "github_token": { "type": "string" },
          "github_owner": { "type": "string" },
          "github_repo": { "type": "string" },
          "github_base_branch": { "type": "string", "default": "main" }
        }
      },
      "definition": {
        "start": "discover_ready_issues",
        "concurrency": 1,
        "metadata": {
          "domain": "sdlc",
          "description": "Find Jira automation items and process each issue through an isolated SDLC subflow."
        },
        "nodes": [
          {
            "id": "discover_ready_issues",
            "kind": "task",
            "task_id": 201,
            "parameters": {
              "base_url": { "$ref": { "input": ["jira_base_url"] } },
              "token": { "$ref": { "input": ["jira_token"] } },
              "email": { "$ref": { "input": ["jira_email"] } },
              "jql": { "$ref": { "input": ["jira_jql"] } }
            },
            "transitions": { "on_success": { "$node": "process_each_issue" } }
          },
          {
            "id": "process_each_issue",
            "kind": "map",
            "parameters": {
              "items": { "$ref": { "node": "discover_ready_issues", "output": ["issues"] } },
              "target": { "$node": "process_issue" },
              "concurrency": 1
            },
            "transitions": { "next": { "$node": "complete" } }
          },
          {
            "id": "process_issue",
            "kind": "subflow",
            "subflow_id": 1004,
            "parameters": {
              "issue": { "$ref": { "workflow": ["state", "map", "item"] } },
              "jira_base_url": { "$ref": { "input": ["jira_base_url"] } },
              "jira_token": { "$ref": { "input": ["jira_token"] } },
              "jira_email": { "$ref": { "input": ["jira_email"] } },
              "jira_done_transition_id": { "$ref": { "input": ["jira_done_transition_id"] } },
              "jira_rework_transition_id": { "$ref": { "input": ["jira_rework_transition_id"] } },
              "git_repo": { "$ref": { "input": ["git_repo"] } },
              "workspace_root": { "$ref": { "input": ["workspace_root"] } },
              "implementation_command": { "$ref": { "input": ["implementation_command"] } },
              "github_token": { "$ref": { "input": ["github_token"] } },
              "github_owner": { "$ref": { "input": ["github_owner"] } },
              "github_repo": { "$ref": { "input": ["github_repo"] } },
              "github_base_branch": { "$ref": { "input": ["github_base_branch"] } }
            },
            "transitions": { "on_success": { "$node": "process_each_issue" } }
          },
          {
            "id": "complete",
            "kind": "end"
          }
        ],
        "ui": {
          "layout": {
            "discover_ready_issues": { "x": 0, "y": 0 },
            "process_each_issue": { "x": 240, "y": 0 },
            "process_issue": { "x": 480, "y": 0 },
            "complete": { "x": 720, "y": 0 }
          }
        }
      }
    },
    {
      "id": 1004,
      "name": "SDLC: Process Issue",
      "version": 1,
      "enabled": true,
      "input_schema": {
        "type": "object",
        "additionalProperties": true
      },
      "definition": {
        "start": "create_worktree",
        "concurrency": 1,
        "metadata": {
          "domain": "sdlc",
          "description": "Process one Jira issue through implementation, PR checks, QA, merge, cleanup, and bounded rework."
        },
        "nodes": [
          {
            "id": "create_worktree",
            "kind": "task",
            "task_id": 202,
            "parameters": {
              "repo": { "$ref": { "input": ["git_repo"] } },
              "branch": {
                "$concat": ["codex/", { "$ref": { "input": ["issue", "key"] } }]
              },
              "path": {
                "$concat": [
                  { "$ref": { "input": ["workspace_root"] } },
                  "/",
                  { "$ref": { "input": ["issue", "key"] } }
                ]
              }
            },
            "transitions": { "on_success": { "$node": "implement_change" } }
          },
          {
            "id": "implement_change",
            "kind": "task",
            "task_id": 203,
            "reentry": {
              "enabled": true,
              "max_visits": 3,
              "on_exhausted": { "$node": "comment_rework_exhausted" }
            },
            "parameters": {
              "command": { "$ref": { "input": ["implementation_command"] } },
              "input": {
                "issue": { "$ref": { "input": ["issue"] } },
                "workspace": {
                  "$concat": [
                    { "$ref": { "input": ["workspace_root"] } },
                    "/",
                    { "$ref": { "input": ["issue", "key"] } }
                  ]
                }
              }
            },
            "transitions": { "on_success": { "$node": "commit_work" } }
          },
          {
            "id": "commit_work",
            "kind": "task",
            "task_id": 204,
            "parameters": {
              "workspace": {
                "$concat": [
                  { "$ref": { "input": ["workspace_root"] } },
                  "/",
                  { "$ref": { "input": ["issue", "key"] } }
                ]
              },
              "message": {
                "$concat": ["Implement ", { "$ref": { "input": ["issue", "key"] } }]
              }
            },
            "transitions": { "on_success": { "$node": "push_branch" } }
          },
          {
            "id": "push_branch",
            "kind": "task",
            "task_id": 209,
            "parameters": {
              "workspace": {
                "$concat": [
                  { "$ref": { "input": ["workspace_root"] } },
                  "/",
                  { "$ref": { "input": ["issue", "key"] } }
                ]
              },
              "branch": {
                "$concat": ["codex/", { "$ref": { "input": ["issue", "key"] } }]
              },
              "remote": "origin",
              "set_upstream": true
            },
            "transitions": { "on_success": { "$node": "open_pull_request" } }
          },
          {
            "id": "open_pull_request",
            "kind": "task",
            "task_id": 205,
            "parameters": {
              "token": { "$ref": { "input": ["github_token"] } },
              "owner": { "$ref": { "input": ["github_owner"] } },
              "repo": { "$ref": { "input": ["github_repo"] } },
              "title": {
                "$concat": [
                  { "$ref": { "input": ["issue", "key"] } },
                  ": automated implementation"
                ]
              },
              "head": {
                "$concat": ["codex/", { "$ref": { "input": ["issue", "key"] } }]
              },
              "base_branch": { "$ref": { "input": ["github_base_branch"] } },
              "body": "Created by Runinator SDLC automation."
            },
            "transitions": { "on_success": { "$node": "wait_for_checks" } }
          },
          {
            "id": "wait_for_checks",
            "kind": "wait",
            "wait": { "seconds": 60 },
            "reentry": {
              "enabled": true,
              "max_visits": 20,
              "on_exhausted": { "$node": "comment_checks_failed" }
            },
            "transitions": { "next": { "$node": "summarize_checks" } }
          },
          {
            "id": "summarize_checks",
            "kind": "task",
            "task_id": 206,
            "parameters": {
              "token": { "$ref": { "input": ["github_token"] } },
              "owner": { "$ref": { "input": ["github_owner"] } },
              "repo": { "$ref": { "input": ["github_repo"] } },
              "ref": {
                "$concat": ["codex/", { "$ref": { "input": ["issue", "key"] } }]
              }
            },
            "transitions": {
              "on_success": { "$node": "route_check_status" },
              "on_failure": { "$node": "comment_checks_failed" }
            }
          },
          {
            "id": "route_check_status",
            "kind": "switch",
            "parameters": {
              "value": { "$ref": { "node": "summarize_checks", "output": ["status"] } },
              "cases": [
                { "equals": "failed", "target": { "$node": "comment_checks_failed" } },
                { "equals": "pending", "target": { "$node": "wait_for_checks" } }
              ],
              "default": { "$node": "qa_approval" }
            }
          },
          {
            "id": "qa_approval",
            "kind": "approval",
            "parameters": {
              "approval_type": "qa",
              "prompt": "Approve QA for the generated SDLC pull request."
            },
            "transitions": {
              "on_success": { "$node": "merge_approval" },
              "on_failure": { "$node": "comment_qa_rejected" }
            }
          },
          {
            "id": "merge_approval",
            "kind": "approval",
            "parameters": {
              "approval_type": "merge",
              "prompt": "Approve merge of the generated pull request."
            },
            "transitions": {
              "on_success": { "$node": "merge_pull_request" },
              "on_failure": { "$node": "comment_merge_rejected" }
            }
          },
          {
            "id": "merge_pull_request",
            "kind": "task",
            "task_id": 208,
            "parameters": {
              "token": { "$ref": { "input": ["github_token"] } },
              "owner": { "$ref": { "input": ["github_owner"] } },
              "repo": { "$ref": { "input": ["github_repo"] } },
              "pull_number": {
                "$concat": [
                  "",
                  { "$ref": { "node": "open_pull_request", "output": ["number"] } }
                ]
              },
              "merge_method": "squash",
              "commit_title": {
                "$concat": [
                  { "$ref": { "input": ["issue", "key"] } },
                  ": automated implementation"
                ]
              },
              "commit_message": "Merged by Runinator SDLC automation."
            },
            "transitions": { "on_success": { "$node": "move_issue_to_done" } }
          },
          {
            "id": "move_issue_to_done",
            "kind": "task",
            "task_id": 207,
            "parameters": {
              "base_url": { "$ref": { "input": ["jira_base_url"] } },
              "token": { "$ref": { "input": ["jira_token"] } },
              "email": { "$ref": { "input": ["jira_email"] } },
              "key": { "$ref": { "input": ["issue", "key"] } },
              "transition_id": { "$ref": { "input": ["jira_done_transition_id"] } }
            },
            "transitions": { "on_success": { "$node": "cleanup_worktree" } }
          },
          {
            "id": "cleanup_worktree",
            "kind": "task",
            "task_id": 211,
            "parameters": {
              "repo": { "$ref": { "input": ["git_repo"] } },
              "path": {
                "$concat": [
                  { "$ref": { "input": ["workspace_root"] } },
                  "/",
                  { "$ref": { "input": ["issue", "key"] } }
                ]
              }
            },
            "transitions": { "on_success": { "$node": "complete" } }
          },
          {
            "id": "comment_checks_failed",
            "kind": "task",
            "task_id": 210,
            "parameters": {
              "base_url": { "$ref": { "input": ["jira_base_url"] } },
              "token": { "$ref": { "input": ["jira_token"] } },
              "email": { "$ref": { "input": ["jira_email"] } },
              "key": { "$ref": { "input": ["issue", "key"] } },
              "body": "Runinator checks failed or timed out; returning this issue for rework."
            },
            "transitions": { "on_success": { "$node": "transition_to_rework" } }
          },
          {
            "id": "comment_qa_rejected",
            "kind": "task",
            "task_id": 210,
            "parameters": {
              "base_url": { "$ref": { "input": ["jira_base_url"] } },
              "token": { "$ref": { "input": ["jira_token"] } },
              "email": { "$ref": { "input": ["jira_email"] } },
              "key": { "$ref": { "input": ["issue", "key"] } },
              "body": "QA rejected the generated pull request; returning this issue for rework."
            },
            "transitions": { "on_success": { "$node": "transition_to_rework" } }
          },
          {
            "id": "comment_merge_rejected",
            "kind": "task",
            "task_id": 210,
            "parameters": {
              "base_url": { "$ref": { "input": ["jira_base_url"] } },
              "token": { "$ref": { "input": ["jira_token"] } },
              "email": { "$ref": { "input": ["jira_email"] } },
              "key": { "$ref": { "input": ["issue", "key"] } },
              "body": "Merge approval was rejected; returning this issue for rework."
            },
            "transitions": { "on_success": { "$node": "transition_to_rework" } }
          },
          {
            "id": "comment_rework_exhausted",
            "kind": "task",
            "task_id": 210,
            "parameters": {
              "base_url": { "$ref": { "input": ["jira_base_url"] } },
              "token": { "$ref": { "input": ["jira_token"] } },
              "email": { "$ref": { "input": ["jira_email"] } },
              "key": { "$ref": { "input": ["issue", "key"] } },
              "body": "Runinator exhausted automated rework attempts; leaving this issue for manual follow-up."
            },
            "transitions": { "on_success": { "$node": "transition_rework_deferred" } }
          },
          {
            "id": "transition_to_rework",
            "kind": "task",
            "task_id": 212,
            "parameters": {
              "base_url": { "$ref": { "input": ["jira_base_url"] } },
              "token": { "$ref": { "input": ["jira_token"] } },
              "email": { "$ref": { "input": ["jira_email"] } },
              "key": { "$ref": { "input": ["issue", "key"] } },
              "transition_id": { "$ref": { "input": ["jira_rework_transition_id"] } }
            },
            "transitions": { "on_success": { "$node": "implement_change" } }
          },
          {
            "id": "transition_rework_deferred",
            "kind": "task",
            "task_id": 212,
            "parameters": {
              "base_url": { "$ref": { "input": ["jira_base_url"] } },
              "token": { "$ref": { "input": ["jira_token"] } },
              "email": { "$ref": { "input": ["jira_email"] } },
              "key": { "$ref": { "input": ["issue", "key"] } },
              "transition_id": { "$ref": { "input": ["jira_rework_transition_id"] } }
            },
            "transitions": { "on_success": { "$node": "deferred" } }
          },
          {
            "id": "deferred",
            "kind": "end"
          },
          {
            "id": "complete",
            "kind": "end"
          }
        ],
        "ui": {
          "layout": {
            "create_worktree": { "x": 0, "y": 0 },
            "implement_change": { "x": 240, "y": 0 },
            "commit_work": { "x": 480, "y": 0 },
            "push_branch": { "x": 720, "y": 0 },
            "open_pull_request": { "x": 960, "y": 0 },
            "wait_for_checks": { "x": 1200, "y": 0 },
            "summarize_checks": { "x": 1440, "y": 0 },
            "route_check_status": { "x": 1680, "y": 0 },
            "qa_approval": { "x": 1920, "y": 0 },
            "merge_approval": { "x": 2160, "y": 0 },
            "merge_pull_request": { "x": 2400, "y": 0 },
            "move_issue_to_done": { "x": 2640, "y": 0 },
            "cleanup_worktree": { "x": 2880, "y": 0 },
            "comment_checks_failed": { "x": 1440, "y": 220 },
            "comment_qa_rejected": { "x": 1920, "y": 220 },
            "comment_merge_rejected": { "x": 2160, "y": 220 },
            "transition_to_rework": { "x": 2160, "y": 420 },
            "comment_rework_exhausted": { "x": 240, "y": 220 },
            "transition_rework_deferred": { "x": 480, "y": 220 },
            "deferred": { "x": 720, "y": 220 },
            "complete": { "x": 3120, "y": 0 }
          }
        }
      }
    },
    {
      "id": 1002,
      "name": "Rich Workflow Syntax Demo",
      "version": 1,
      "enabled": true,
      "input_schema": {},
      "definition": {
        "start": "route_mode",
        "metadata": {
          "domain": "workflow-dsl",
          "description": "Demonstrates switch, parallel, join, try, map, race, and emit nodes."
        },
        "nodes": [
          {
            "id": "route_mode",
            "kind": "switch",
            "parameters": {
              "value": { "$ref": { "input": ["mode"] } },
              "cases": [
                { "equals": "batch", "target": { "$node": "process_items" } },
                { "equals": "race", "target": { "$node": "first_ready" } }
              ],
              "default": { "$node": "start_checks" }
            }
          },
          {
            "id": "start_checks",
            "kind": "parallel",
            "parameters": {
              "branches": [{ "$node": "lint_check" }, { "$node": "unit_check" }]
            }
          },
          {
            "id": "lint_check",
            "kind": "emit",
            "parameters": {
              "event_type": "check.completed",
              "data": { "name": "lint", "status": "ok" }
            },
            "transitions": { "next": { "$node": "checks_joined" } }
          },
          {
            "id": "unit_check",
            "kind": "emit",
            "parameters": {
              "event_type": "check.completed",
              "data": { "name": "unit", "status": "ok" }
            },
            "transitions": { "next": { "$node": "checks_joined" } }
          },
          {
            "id": "checks_joined",
            "kind": "join",
            "parameters": {
              "wait_for": [{ "$node": "lint_check" }, { "$node": "unit_check" }],
              "mode": "all"
            },
            "transitions": { "next": { "$node": "guarded_release" } }
          },
          {
            "id": "guarded_release",
            "kind": "try",
            "parameters": {
              "body": { "$node": "release_body" },
              "catch": { "$node": "release_recovery" },
              "finally": { "$node": "release_cleanup" }
            },
            "transitions": { "next": { "$node": "done" } }
          },
          {
            "id": "release_body",
            "kind": "emit",
            "parameters": {
              "event_type": "release.body",
              "data": { "status": "ok" }
            },
            "transitions": { "next": { "$node": "guarded_release" } }
          },
          {
            "id": "release_recovery",
            "kind": "emit",
            "parameters": {
              "event_type": "release.recovery",
              "data": { "status": "recovered" }
            },
            "transitions": { "next": { "$node": "guarded_release" } }
          },
          {
            "id": "release_cleanup",
            "kind": "emit",
            "parameters": {
              "event_type": "release.cleanup",
              "data": { "status": "done" }
            },
            "transitions": { "next": { "$node": "guarded_release" } }
          },
          {
            "id": "process_items",
            "kind": "map",
            "parameters": {
              "items": { "$ref": { "input": ["items"] } },
              "target": { "$node": "process_item" },
              "concurrency": 1
            },
            "transitions": { "next": { "$node": "done" } }
          },
          {
            "id": "process_item",
            "kind": "emit",
            "parameters": {
              "event_type": "item.processed",
              "data": {
                "index": { "$ref": { "workflow": ["state", "map", "index"] } },
                "item": { "$ref": { "workflow": ["state", "map", "item"] } }
              }
            },
            "transitions": { "next": { "$node": "process_items" } }
          },
          {
            "id": "first_ready",
            "kind": "race",
            "parameters": {
              "branches": [{ "$node": "fast_signal" }, { "$node": "slow_signal" }],
              "winner": "first_success"
            },
            "transitions": { "next": { "$node": "done" } }
          },
          {
            "id": "fast_signal",
            "kind": "emit",
            "parameters": {
              "event_type": "signal.ready",
              "data": { "source": "fast" }
            },
            "transitions": { "next": { "$node": "first_ready" } }
          },
          {
            "id": "slow_signal",
            "kind": "emit",
            "parameters": {
              "event_type": "signal.ready",
              "data": { "source": "slow" }
            },
            "transitions": { "next": { "$node": "first_ready" } }
          },
          {
            "id": "done",
            "kind": "end"
          }
        ],
        "ui": {
          "layout": {
            "route_mode": { "x": 0, "y": 0 },
            "start_checks": { "x": 240, "y": 0 },
            "lint_check": { "x": 480, "y": -100 },
            "unit_check": { "x": 480, "y": 100 },
            "checks_joined": { "x": 720, "y": 0 },
            "guarded_release": { "x": 960, "y": 0 },
            "release_body": { "x": 1200, "y": -120 },
            "release_recovery": { "x": 1200, "y": 0 },
            "release_cleanup": { "x": 1200, "y": 120 },
            "process_items": { "x": 240, "y": 300 },
            "process_item": { "x": 480, "y": 300 },
            "first_ready": { "x": 240, "y": 520 },
            "fast_signal": { "x": 480, "y": 460 },
            "slow_signal": { "x": 480, "y": 580 },
            "done": { "x": 1440, "y": 0 }
          }
        }
      }
    }
  ]
}

{
  "Workflow": {
    "prefix": "workflow",
    "body": ["workflow \"${1:Name}\" v${2:1} {", "\t$0", "}"],
    "description": "Workflow scaffold"
  },
  "Params block": {
    "prefix": "params",
    "body": ["params {", "\t${1:name}: ${2:string}", "}"],
    "description": "Workflow params block"
  },
  "Task node": {
    "prefix": "task",
    "body": ["node ${1:result} <- ${2:console}.${3:run}(${4:command}: ${5:\"echo hi\"})", "\t-> ${6:done}"],
    "description": "Provider action bound to a node"
  },
  "Action call": {
    "prefix": "action",
    "body": ["${1:provider}.${2:action}(${3:param}: ${4:value})"],
    "description": "Provider action call"
  },
  "If / else": {
    "prefix": "if",
    "body": ["if ${1:condition} {", "\t$0", "} else {", "\t", "}"],
    "description": "Conditional block"
  },
  "For loop": {
    "prefix": "for",
    "body": ["for ${1:item} in ${2:params.items} {", "\t$0", "}"],
    "description": "For-each loop"
  },
  "Map (fan-out)": {
    "prefix": "map",
    "body": ["map ${1:item} in ${2:params.items} concurrency ${3:none} {", "\t$0", "}"],
    "description": "Map fan-out over items"
  },
  "Parallel / join": {
    "prefix": "parallel",
    "body": ["parallel {", "\tbranch {", "\t\t$1", "\t}", "\tbranch {", "\t\t$2", "\t}", "} join ${3|all,any,first_success|}"],
    "description": "Parallel branches with a join policy"
  },
  "Try / catch / finally": {
    "prefix": "try",
    "body": ["try {", "\t$1", "} catch {", "\t$2", "} finally {", "\t$3", "}"],
    "description": "Try / catch / finally"
  },
  "Match": {
    "prefix": "match",
    "body": ["match ${1:expr} {", "\t${2:value} -> ${3:done}", "\telse -> ${4:fail}", "}"],
    "description": "Match statement"
  },
  "Wait": {
    "prefix": "wait",
    "body": ["wait ${1:30s}"],
    "description": "Wait for a duration"
  },
  "Subflow": {
    "prefix": "subflow",
    "body": ["node ${1:child} <- subflow(\"${2:Workflow}\", params: {", "\t${3:key}: ${4:value}", "})"],
    "description": "Subflow call"
  },
  "Emit": {
    "prefix": "emit",
    "body": ["emit ${1:\"workflow.done\"} { ${2:key}: ${3:value} }"],
    "description": "Emit workflow output data"
  },
  "Yield": {
    "prefix": "yield",
    "body": ["yield ${1:value}"],
    "description": "Yield a control-region value"
  },
  "Approval gate": {
    "prefix": "approve",
    "body": ["approve ${1:\"Approve this step?\"} type ${2:\"manual\"}"],
    "description": "Approval gate"
  },
  "Cron trigger": {
    "prefix": "trigger",
    "body": ["trigger cron \"${1:0 9 * * *}\""],
    "description": "Header cron trigger"
  }
}

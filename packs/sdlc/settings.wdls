// SDLC Automation Pack settings.
//
// every entry below is a config.*/secret.* value the pack's workflows reference,
// so each is required. replace every `<<insert here>>` with a real value before
// running the pipeline. non-string slots use a typed placeholder (`0`, an array)
// so the pack still imports and type-checks.

// jira connection.
config jira.base_url = "<<insert here>>"
config jira.email = "<<insert here>>"

// jql the scanner pulls fresh work from: my tickets, current sprint, Ready for
// Development. e.g. "assignee = currentUser() AND sprint in openSprints() AND
// status = 'Ready for Development' ORDER BY priority DESC".
config jira.ready_jql = "<<insert here>>"
// jql counting tickets already in flight (statuses the automation manages), used
// to enforce the concurrency cap. e.g. "assignee = currentUser() AND sprint in
// openSprints() AND status in ('In Progress','In Review','Ready for Testing','In Testing')".
config jira.in_flight_jql = "<<insert here>>"

// per-phase inbox jqls for the status-scanner pipeline. each phase pulls the tickets
// currently in its inbox status that the automation owns, processes them, and advances
// them to the next status (the handoff between chained phase workflows).
// in_review: work awaiting automated + human review. e.g. "... AND status = 'In Review'".
config jira.in_review_jql = "<<insert here>>"
// deploy: merged work awaiting deploy dispatch. e.g. "... AND status = 'Ready for Testing'".
config jira.deploy_jql = "<<insert here>>"
// qa: deployed work awaiting a QA outcome. e.g. "... AND status = 'In Testing'".
config jira.qa_jql = "<<insert here>>"

// jira status display names, used for drift detection (comparing what a human set
// against what the automation expects at each park point).
config status.ready_for_dev = "Ready for Development"
config status.in_progress = "In Progress"
config status.in_review = "In Review"
config status.ready_for_testing = "Ready for Testing"
config status.in_testing = "In Testing"
config status.done = "Done"
config status.terminal = ["Cancelled", "Won't Do"]

// jira workflow transition ids (project specific).
config transitions.in_progress = "<<insert here>>"
config transitions.in_review = "<<insert here>>"
config transitions.ready_for_testing = "<<insert here>>"
// deploy moves a merged ticket Ready for Testing -> In Testing so QA scans a distinct inbox.
config transitions.in_testing = "<<insert here>>"
config transitions.done = "<<insert here>>"
config transitions.back_to_dev = "<<insert here>>"

// github repository the automation opens, reviews, merges, and deploys against.
config github.owner = "jonfast565"
config github.repo = "firestarter"
config github.base_branch = "main"

// branch naming: branches are <prefix><TICKET-KEY>, e.g. jfast/PROJ-123.
config branch.prefix = "jfast/"

// reviewers requested on every PR and the assignee set on the ticket/PR.
config review.reviewers = ["jonfast565"]
config review.assignees = ["jonfast565"]

// max number of ticket subflows allowed in flight at once.
config selection.max_in_flight = 3

// local git checkout used for worktrees, the remote to push to, and the parent
// directory worktrees are created under.
config git.repo = "<<insert here>>"
config git.remote = "origin"
config git.worktree_root = "<<insert here>>"

// poll/wait cadences (seconds unless a duration literal is used in the workflow).
config ci_poll.interval_seconds = 60
config waits.integration_seconds = 900
config waits.claude_seconds = 600
config waits.review_poll_seconds = 1800
config waits.post_approval_seconds = 86400
config waits.qa_poll_seconds = 1800
config waits.deploy_settle_seconds = 120

// path-based deploy detection: prefixes that map a changed file to a deploy
// target, and the github actions workflow file dispatched for each target.
config deploy.api_prefix = "src/api/"
config deploy.dashboard_prefix = "dashboards/"
config deploy.lambda_prefix = "lambdas/"
config deploy.api_workflow = "deploy-api.yml"
config deploy.dashboard_workflow = "deploy-dashboards.yml"
config deploy.lambda_workflow = "deploy-lambda.yml"

// claude code agent configuration.
config claude.binary = "claude"
config claude.model = "claude-opus-4-8"
config claude.output_format = "text"
config claude.allowed_tools = "<<insert here>>"
config claude.permission_mode = "<<insert here>>"
config claude.extra_args = ["<<insert here>>"]
// implement prompt. claude is told to read the ticket's full comment history so a
// re-picked ticket (after QA bounce) picks up the latest direction.
config claude.prompt_intro = "Please complete the JIRA ticket below. Read the full ticket description and all of its comments to determine the course of action, then implement the change in this working tree."
config claude.copilot_prompt = "Address the following GitHub Copilot review feedback in this working tree:"
config claude.claude_feedback_prompt = "The following is automated review feedback from the GitHub /claude reviewer. Fix only the highest-value items. Then output a short summary of what you did NOT fix and why:"
config claude.review_fix_prompt = "A human reviewer requested changes on this PR. Assess whether each comment is valid; fix the valid ones in this working tree, and summarize anything you intentionally left unaddressed and why:"

// api tokens (late-resolved at the worker).
secret jira.token = "<<insert here>>"
secret github.token = "<<insert here>>"
secret slack.token = "<<insert here>>"

// slack channel for success and failure notifications.
config slack.channel = "<<insert here>>"

{
  "uri": "runinator://packs/sdlc",
  "item_type": "workflow_pack",
  "name": "SDLC Automation Pack",
  "version": "1",
  "document": {
    "imports": {
      "jira": "runinator://providers/jira",
      "github": "runinator://providers/github",
      "git": "runinator://providers/git",
      "ai": "runinator://providers/ai-command",
      "approval": "runinator://providers/approval"
    },
    "workflows": {
      "implement_review_qa_until_done": {
        "start": "find_items",
        "metadata": {
          "deployment_dispatch": "opt_in"
        },
        "nodes": [
          {
            "id": "find_items",
            "kind": "task",
            "parameters": {
              "labels": ["automation"],
              "assigned_to": { "$value": "input#/operator_id" }
            },
            "transitions": { "on_success": "for_each_item" }
          },
          {
            "id": "for_each_item",
            "kind": "loop",
            "parameters": {
              "items": { "$value": "steps.find_items.output#/items" }
            },
            "max_iterations": 20,
            "transitions": {
              "next": "create_workspace",
              "on_success": "done"
            }
          },
          {
            "id": "create_workspace",
            "kind": "task",
            "parameters": {
              "item": { "$value": "steps.for_each_item.output#/item" }
            },
            "transitions": { "on_success": "implement_change" }
          },
          {
            "id": "implement_change",
            "kind": "task",
            "parameters": {
              "item": { "$value": "steps.for_each_item.output#/item" },
              "workspace": { "$value": "steps.create_workspace.output#/workspace" }
            },
            "transitions": { "on_success": "create_pr" }
          },
          {
            "id": "create_pr",
            "kind": "task",
            "parameters": {
              "workspace": { "$value": "steps.create_workspace.output#/workspace" },
              "change_set": { "$value": "steps.implement_change.output#/change_set" }
            },
            "transitions": { "on_success": "wait_for_checks" }
          },
          {
            "id": "wait_for_checks",
            "kind": "wait",
            "wait": { "seconds": 60 },
            "transitions": { "next": "read_checks" }
          },
          {
            "id": "read_checks",
            "kind": "task",
            "parameters": {
              "pull_request": { "$value": "steps.create_pr.output#/pull_request" }
            },
            "transitions": {
              "branches": [
                {
                  "when": {
                    "value": { "$value": "steps.read_checks.output#/status" },
                    "equals": "passed"
                  },
                  "target": "merge_approval"
                }
              ],
              "on_failure": "wait_for_checks"
            }
          },
          {
            "id": "merge_approval",
            "kind": "approval",
            "parameters": {
              "approval_type": "merge",
              "prompt": "Approve merge for generated PR"
            },
            "transitions": {
              "on_success": "transition_done",
              "on_failure": "for_each_item"
            }
          },
          {
            "id": "transition_done",
            "kind": "task",
            "parameters": {
              "item": { "$value": "steps.for_each_item.output#/item" },
              "status": "Done"
            },
            "transitions": { "on_success": "for_each_item" }
          },
          {
            "id": "done",
            "kind": "end"
          }
        ]
      }
    }
  },
  "metadata": {
    "domain": "sdlc",
    "core_specific": false
  }
}

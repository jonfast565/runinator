{
  "uri": "runinator://packs/sdlc",
  "item_type": "workflow_pack",
  "name": "SDLC Automation Pack",
  "version": "1",
  "document": {
    "workflows": {
      "implement_review_qa_until_done": {
        "start": "find_items",
        "metadata": {
          "deployment_dispatch": "opt_in"
        },
        "nodes": [
          {
            "id": "find_items",
            "kind": "task",
            "parameters": {
              "labels": ["automation"],
              "assigned_to": { "$ref": { "input": ["operator_id"] } }
            },
            "transitions": { "on_success": { "$node": "for_each_item" } }
          },
          {
            "id": "for_each_item",
            "kind": "loop",
            "parameters": {
              "items": { "$ref": { "node": "find_items", "output": ["items"] } }
            },
            "max_iterations": 20,
            "transitions": {
              "next": { "$node": "create_workspace" },
              "on_success": { "$node": "done" }
            }
          },
          {
            "id": "create_workspace",
            "kind": "task",
            "parameters": {
              "item": { "$ref": { "node": "for_each_item", "output": ["item"] } }
            },
            "transitions": { "on_success": { "$node": "implement_change" } }
          },
          {
            "id": "implement_change",
            "kind": "task",
            "parameters": {
              "item": { "$ref": { "node": "for_each_item", "output": ["item"] } },
              "workspace": { "$ref": { "node": "create_workspace", "output": ["workspace"] } }
            },
            "transitions": { "on_success": { "$node": "create_pr" } }
          },
          {
            "id": "create_pr",
            "kind": "task",
            "parameters": {
              "workspace": { "$ref": { "node": "create_workspace", "output": ["workspace"] } },
              "change_set": { "$ref": { "node": "implement_change", "output": ["change_set"] } }
            },
            "transitions": { "on_success": { "$node": "wait_for_checks" } }
          },
          {
            "id": "wait_for_checks",
            "kind": "wait",
            "wait": { "seconds": 60 },
            "transitions": { "next": { "$node": "read_checks" } }
          },
          {
            "id": "read_checks",
            "kind": "task",
            "parameters": {
              "pull_request": { "$ref": { "node": "create_pr", "output": ["pull_request"] } }
            },
            "transitions": {
              "branches": [
                {
                  "when": {
                    "value": { "$ref": { "node": "read_checks", "output": ["status"] } },
                    "equals": "passed"
                  },
                  "target": { "$node": "merge_approval" }
                }
              ],
              "on_failure": { "$node": "wait_for_checks" }
            }
          },
          {
            "id": "merge_approval",
            "kind": "approval",
            "parameters": {
              "approval_type": "merge",
              "prompt": "Approve merge for generated PR"
            },
            "transitions": {
              "on_success": { "$node": "transition_done" },
              "on_failure": { "$node": "for_each_item" }
            }
          },
          {
            "id": "transition_done",
            "kind": "task",
            "parameters": {
              "item": { "$ref": { "node": "for_each_item", "output": ["item"] } },
              "status": "Done"
            },
            "transitions": { "on_success": { "$node": "for_each_item" } }
          },
          {
            "id": "done",
            "kind": "end"
          }
        ]
      }
    }
  },
  "metadata": {
    "domain": "sdlc",
    "core_specific": false
  }
}

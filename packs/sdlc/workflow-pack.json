{
  "uri": "runinator://packs/sdlc",
  "item_type": "workflow_pack",
  "name": "SDLC Automation Pack",
  "version": "4",
  "document": {
    "workflows": {
      "Core Team SDLC Pipeline": {
        "metadata": {
          "description": "Discovers JIRA tickets ready for automated implementation and starts one Ticket Work workflow run per open ticket.",
          "deployment_dispatch": "opt_in"
        },
        "start": "start",
        "nodes": [
          {
            "id": "start",
            "kind": "start",
            "transitions": {
              "next": {
                "$node": "find_tickets"
              }
            }
          },
          {
            "id": "find_tickets",
            "kind": "action",
            "action": {
              "provider": "jira",
              "function": "search",
              "timeout_seconds": 60,
              "configuration": {
                "base_url": {
                  "$ref": {
                    "input": [
                      "jira",
                      "base_url"
                    ]
                  }
                },
                "email": {
                  "$ref": {
                    "input": [
                      "jira",
                      "email"
                    ]
                  }
                },
                "token": {
                  "$ref": {
                    "input": [
                      "jira",
                      "token"
                    ]
                  }
                },
                "jql": {
                  "$ref": {
                    "input": [
                      "jira",
                      "jql"
                    ]
                  }
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "for_each_ticket"
              }
            }
          },
          {
            "id": "for_each_ticket",
            "kind": "loop",
            "parameters": {
              "items": {
                "$ref": {
                  "node": "find_tickets",
                  "output": [
                    "issues"
                  ]
                }
              }
            },
            "max_iterations": 50,
            "transitions": {
              "next": {
                "$node": "spawn_ticket_work"
              },
              "on_success": {
                "$node": "done"
              }
            }
          },
          {
            "id": "spawn_ticket_work",
            "kind": "subflow",
            "subflow": {
              "workflow_name": "Ticket Work",
              "type": "fire_and_forget",
              "run_name": {
                "$concat": [
                  "Ticket Work: ",
                  {
                    "$ref": {
                      "node": "for_each_ticket",
                      "output": [
                        "item",
                        "key"
                      ]
                    }
                  }
                ]
              },
              "reuse_open_run": true
            },
            "parameters": {
              "ticket": {
                "$ref": {
                  "node": "for_each_ticket",
                  "output": [
                    "item"
                  ]
                }
              },
              "parent_workflow_run_id": {
                "$ref": {
                  "workflow": [
                    "run_id"
                  ]
                }
              },
              "jira": {
                "$ref": {
                  "input": [
                    "jira"
                  ]
                }
              },
              "github": {
                "$ref": {
                  "input": [
                    "github"
                  ]
                }
              },
              "slack": {
                "$ref": {
                  "input": [
                    "slack"
                  ]
                }
              },
              "git": {
                "$ref": {
                  "input": [
                    "git"
                  ]
                }
              },
              "claude": {
                "$ref": {
                  "input": [
                    "claude"
                  ]
                }
              },
              "transitions": {
                "$ref": {
                  "input": [
                    "transitions"
                  ]
                }
              },
              "ci_poll": {
                "$ref": {
                  "input": [
                    "ci_poll"
                  ]
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "for_each_ticket"
              }
            }
          },
          {
            "id": "done",
            "kind": "end"
          }
        ],
        "input_type": {
          "type": "struct",
          "fields": {
            "jira": {
              "type": "struct",
              "fields": {
                "base_url": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "token": {
                  "type": "string"
                },
                "jql": {
                  "type": "string"
                }
              }
            },
            "transitions": {
              "type": "struct",
              "fields": {
                "in_progress": {
                  "type": "string"
                },
                "in_review": {
                  "type": "string"
                },
                "done": {
                  "type": "string"
                }
              }
            },
            "github": {
              "type": "struct",
              "fields": {
                "token": {
                  "type": "string"
                },
                "owner": {
                  "type": "string"
                },
                "repo": {
                  "type": "string"
                },
                "base_branch": {
                  "type": "string"
                }
              }
            },
            "slack": {
              "type": "struct",
              "fields": {
                "token": {
                  "type": "string"
                },
                "channel": {
                  "type": "string"
                }
              }
            },
            "git": {
              "type": "struct",
              "fields": {
                "repo": {
                  "type": "string"
                },
                "remote": {
                  "type": "string"
                }
              }
            },
            "claude": {
              "type": "struct",
              "fields": {
                "binary": {
                  "type": "string"
                },
                "model": {
                  "type": "string"
                },
                "prompt_intro": {
                  "type": "string"
                },
                "allowed_tools": {
                  "type": "string"
                },
                "output_format": {
                  "type": "string"
                },
                "permission_mode": {
                  "type": "string"
                },
                "extra_args": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "ci_poll": {
              "type": "struct",
              "fields": {
                "interval_seconds": {
                  "type": "integer"
                },
                "max_polls": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "Ticket Work": {
        "metadata": {
          "description": "Per-ticket SDLC workflow that implements one JIRA issue, opens and verifies a PR, and transitions the ticket through review and completion.",
          "deployment_dispatch": "child_only"
        },
        "start": "start",
        "nodes": [
          {
            "id": "start",
            "kind": "start",
            "transitions": {
              "next": {
                "$node": "configure_ticket_work"
              }
            }
          },
          {
            "id": "configure_ticket_work",
            "kind": "config",
            "parameters": {
              "name": {
                "$concat": [
                  "Ticket Work: ",
                  {
                    "$ref": {
                      "input": [
                        "ticket",
                        "key"
                      ]
                    }
                  }
                ]
              },
              "metadata": {
                "parent_workflow_run_id": {
                  "$ref": {
                    "input": [
                      "parent_workflow_run_id"
                    ]
                  }
                },
                "ticket_key": {
                  "$ref": {
                    "input": [
                      "ticket",
                      "key"
                    ]
                  }
                }
              }
            },
            "transitions": {
              "next": {
                "$node": "transition_in_progress"
              }
            }
          },
          {
            "id": "transition_in_progress",
            "kind": "action",
            "action": {
              "provider": "jira",
              "function": "transition",
              "timeout_seconds": 30,
              "configuration": {
                "base_url": {
                  "$ref": {
                    "input": [
                      "jira",
                      "base_url"
                    ]
                  }
                },
                "email": {
                  "$ref": {
                    "input": [
                      "jira",
                      "email"
                    ]
                  }
                },
                "token": {
                  "$ref": {
                    "input": [
                      "jira",
                      "token"
                    ]
                  }
                },
                "key": {
                  "$ref": {
                    "input": [
                      "ticket",
                      "key"
                    ]
                  }
                },
                "transition_id": {
                  "$ref": {
                    "input": [
                      "transitions",
                      "in_progress"
                    ]
                  }
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "kickoff_comment"
              },
              "on_failure": {
                "$node": "notify_failure"
              }
            }
          },
          {
            "id": "kickoff_comment",
            "kind": "action",
            "action": {
              "provider": "jira",
              "function": "comment",
              "timeout_seconds": 30,
              "configuration": {
                "base_url": {
                  "$ref": {
                    "input": [
                      "jira",
                      "base_url"
                    ]
                  }
                },
                "email": {
                  "$ref": {
                    "input": [
                      "jira",
                      "email"
                    ]
                  }
                },
                "token": {
                  "$ref": {
                    "input": [
                      "jira",
                      "token"
                    ]
                  }
                },
                "key": {
                  "$ref": {
                    "input": [
                      "ticket",
                      "key"
                    ]
                  }
                },
                "body": {
                  "$concat": [
                    "Automation started for ",
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "key"
                        ]
                      }
                    },
                    ". Run ",
                    {
                      "$to_string": {
                        "$ref": {
                          "workflow": [
                            "run_id"
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "create_workspace"
              }
            }
          },
          {
            "id": "create_workspace",
            "kind": "action",
            "action": {
              "provider": "git",
              "function": "worktree",
              "timeout_seconds": 120,
              "configuration": {
                "repo": {
                  "$ref": {
                    "input": [
                      "git",
                      "repo"
                    ]
                  }
                },
                "branch": {
                  "$concat": [
                    "feature/",
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "key"
                        ]
                      }
                    }
                  ]
                },
                "path": {
                  "$concat": [
                    {
                      "$ref": {
                        "input": [
                          "git",
                          "repo"
                        ]
                      }
                    },
                    "/../runinator-worktrees/",
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "key"
                        ]
                      }
                    }
                  ]
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "implement_change"
              },
              "on_failure": {
                "$node": "notify_failure"
              }
            }
          },
          {
            "id": "implement_change",
            "kind": "action",
            "action": {
              "provider": "ai-command",
              "function": "claude_code",
              "timeout_seconds": 1800,
              "configuration": {
                "binary": {
                  "$ref": {
                    "input": [
                      "claude",
                      "binary"
                    ]
                  }
                },
                "model": {
                  "$ref": {
                    "input": [
                      "claude",
                      "model"
                    ]
                  }
                },
                "output_format": {
                  "$ref": {
                    "input": [
                      "claude",
                      "output_format"
                    ]
                  }
                },
                "allowed_tools": {
                  "$ref": {
                    "input": [
                      "claude",
                      "allowed_tools"
                    ]
                  }
                },
                "permission_mode": {
                  "$ref": {
                    "input": [
                      "claude",
                      "permission_mode"
                    ]
                  }
                },
                "extra_args": {
                  "$ref": {
                    "input": [
                      "claude",
                      "extra_args"
                    ]
                  }
                },
                "working_dir": {
                  "$ref": {
                    "node": "create_workspace",
                    "output": [
                      "workspace"
                    ]
                  }
                },
                "prompt": {
                  "$concat": [
                    {
                      "$ref": {
                        "input": [
                          "claude",
                          "prompt_intro"
                        ]
                      }
                    },
                    "\n\nTicket: ",
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "key"
                        ]
                      }
                    },
                    "\nSummary: ",
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "fields",
                          "summary"
                        ]
                      }
                    },
                    "\n\nFull issue payload follows as JSON:\n",
                    {
                      "$to_json_string": {
                        "$ref": {
                          "input": [
                            "ticket"
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "commit_change"
              },
              "on_failure": {
                "$node": "notify_failure"
              }
            }
          },
          {
            "id": "commit_change",
            "kind": "action",
            "action": {
              "provider": "git",
              "function": "commit",
              "timeout_seconds": 60,
              "configuration": {
                "workspace": {
                  "$ref": {
                    "node": "create_workspace",
                    "output": [
                      "workspace"
                    ]
                  }
                },
                "message": {
                  "$concat": [
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "key"
                        ]
                      }
                    },
                    " ",
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "fields",
                          "summary"
                        ]
                      }
                    }
                  ]
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "push_branch"
              },
              "on_failure": {
                "$node": "notify_failure"
              }
            }
          },
          {
            "id": "push_branch",
            "kind": "action",
            "action": {
              "provider": "git",
              "function": "push",
              "timeout_seconds": 60,
              "configuration": {
                "workspace": {
                  "$ref": {
                    "node": "create_workspace",
                    "output": [
                      "workspace"
                    ]
                  }
                },
                "remote": {
                  "$ref": {
                    "input": [
                      "git",
                      "remote"
                    ]
                  }
                },
                "branch": {
                  "$concat": [
                    "feature/",
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "key"
                        ]
                      }
                    }
                  ]
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "create_pr"
              },
              "on_failure": {
                "$node": "notify_failure"
              }
            }
          },
          {
            "id": "create_pr",
            "kind": "action",
            "action": {
              "provider": "github",
              "function": "create_pr",
              "timeout_seconds": 60,
              "configuration": {
                "token": {
                  "$ref": {
                    "input": [
                      "github",
                      "token"
                    ]
                  }
                },
                "owner": {
                  "$ref": {
                    "input": [
                      "github",
                      "owner"
                    ]
                  }
                },
                "repo": {
                  "$ref": {
                    "input": [
                      "github",
                      "repo"
                    ]
                  }
                },
                "base": {
                  "$ref": {
                    "input": [
                      "github",
                      "base_branch"
                    ]
                  }
                },
                "head": {
                  "$concat": [
                    "feature/",
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "key"
                        ]
                      }
                    }
                  ]
                },
                "title": {
                  "$concat": [
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "key"
                        ]
                      }
                    },
                    ": ",
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "fields",
                          "summary"
                        ]
                      }
                    }
                  ]
                },
                "body": {
                  "$concat": [
                    "Automated implementation for ",
                    {
                      "$ref": {
                        "input": [
                          "ticket",
                          "key"
                        ]
                      }
                    },
                    "."
                  ]
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "link_pr_to_ticket"
              },
              "on_failure": {
                "$node": "notify_failure"
              }
            }
          },
          {
            "id": "link_pr_to_ticket",
            "kind": "action",
            "action": {
              "provider": "jira",
              "function": "comment",
              "timeout_seconds": 30,
              "configuration": {
                "base_url": {
                  "$ref": {
                    "input": [
                      "jira",
                      "base_url"
                    ]
                  }
                },
                "email": {
                  "$ref": {
                    "input": [
                      "jira",
                      "email"
                    ]
                  }
                },
                "token": {
                  "$ref": {
                    "input": [
                      "jira",
                      "token"
                    ]
                  }
                },
                "key": {
                  "$ref": {
                    "input": [
                      "ticket",
                      "key"
                    ]
                  }
                },
                "body": {
                  "$concat": [
                    "Pull request opened: ",
                    {
                      "$ref": {
                        "node": "create_pr",
                        "output": [
                          "html_url"
                        ]
                      }
                    }
                  ]
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "transition_in_review"
              }
            }
          },
          {
            "id": "transition_in_review",
            "kind": "action",
            "action": {
              "provider": "jira",
              "function": "transition",
              "timeout_seconds": 30,
              "configuration": {
                "base_url": {
                  "$ref": {
                    "input": [
                      "jira",
                      "base_url"
                    ]
                  }
                },
                "email": {
                  "$ref": {
                    "input": [
                      "jira",
                      "email"
                    ]
                  }
                },
                "token": {
                  "$ref": {
                    "input": [
                      "jira",
                      "token"
                    ]
                  }
                },
                "key": {
                  "$ref": {
                    "input": [
                      "ticket",
                      "key"
                    ]
                  }
                },
                "transition_id": {
                  "$ref": {
                    "input": [
                      "transitions",
                      "in_review"
                    ]
                  }
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "wait_for_ci"
              }
            }
          },
          {
            "id": "wait_for_ci",
            "kind": "wait",
            "wait": {
              "seconds": {
                "$ref": {
                  "input": [
                    "ci_poll",
                    "interval_seconds"
                  ]
                }
              }
            },
            "reentry": {
              "enabled": true,
              "max_visits": 30,
              "on_exhausted": {
                "$node": "notify_failure"
              }
            },
            "transitions": {
              "next": {
                "$node": "poll_checks"
              }
            }
          },
          {
            "id": "poll_checks",
            "kind": "action",
            "action": {
              "provider": "github",
              "function": "checks_summary",
              "timeout_seconds": 30,
              "configuration": {
                "token": {
                  "$ref": {
                    "input": [
                      "github",
                      "token"
                    ]
                  }
                },
                "owner": {
                  "$ref": {
                    "input": [
                      "github",
                      "owner"
                    ]
                  }
                },
                "repo": {
                  "$ref": {
                    "input": [
                      "github",
                      "repo"
                    ]
                  }
                },
                "ref": {
                  "$ref": {
                    "node": "create_pr",
                    "output": [
                      "head",
                      "sha"
                    ]
                  }
                }
              }
            },
            "transitions": {
              "on_success": {
                "$node": "evaluate_checks"
              }
            }
          },
          {
            "id": "evaluate_checks",
            "kind": "switch",
            "parameters": {
              "value": {
                "$ref": {
                  "node": "poll_checks",
                  "output": [
                    "status"
                  ]
                }
              },
              "cases": [
                {
                  "when": {
                    "value": {
                      "$ref": {
                        "node": "poll_checks",
                        "output": [
                          "status"
                        ]
                      }
                    },
                    "equals": "passed"
                  },
                  "target": {
                    "$node": "review_gate"
                  }
                },
                {
                  "when": {
                    "value": {
                      "$ref": {
                        "node": "poll_checks",
                        "output": [
                          "status"
                        ]
                      }
                    },
                    "equals": "failed"
                  },
                  "target": {
                    "$node": "notify_failure"
                  }
                }
              ],
              "default": {
                "$node": "wait_for_ci"
              }
            }
          },
          {
            "id": "review_gate",
            "kind": "approval",
            "parameters": {
              "approval_type": "merge",
              "prompt": {
                "$concat": [
                  "Approve merge of automated PR for ",
                  {
                    "$ref": {
                      "input": [
                        "ticket",
                        "key"
                      ]
                    }
                  }
                ]
              }
            },
            "transitions": {
              "on_success": {
                "$node": "merge_pr"
              },
              "on_reject": {
                "$node": "comment_rejected"
              }
            }
          },
          {
            "id": "merge_pr",
            "kind": "action",
            "action": {
              "provider": "github",
              "function": "merge_pr",
              "timeout_seconds": 60,
              "configuration": {
                "token": {
                  "$ref": {
                    "input": [
                      "github",
                      "token"
                    ]
                  }
                },
                "owner": {
                  "$ref": {
                    "input": [
                      "github",
                      "owner"
                    ]
                  }
                },
                "repo": {
                  "$ref": {
                    "input": [
                      "github",
                      "repo"
                    ]
                  }
                },
                "pull_number": {
                  "$to_string": {
                    "$ref": {
                      "node": "create_pr",
                      "output": [
                        "number"
                      ]
                    }
                  }
                },
                "merge_method": "squash"
              }
            },
            "transitions": {
              "on_success": {
                "$node": "transition_done"
              },
              "on_failure": {
                "$node": "notify_failure"
              }
            }
          },
          {
            "id": "transition_done",
            "kind": "action",
            "action": {
              "provider": "jira",
              "function": "transition",
              "timeout_seconds": 30,
              "configuration": {
                "base_url": {
                  "$ref": {
                    "input": [
                      "jira",
                      "base_url"
                    ]
                  }
                },
                "email": {
                  "$ref": {
                    "input": [
                      "jira",
                      "email"
                    ]
                  }
                },
                "token": {
                  "$ref": {
                    "input": [
                      "jira",
                      "token"
                    ]
                  }
                },
                "key": {
                  "$ref": {
                    "input": [
                      "ticket",
                      "key"
                    ]
                  }
                },
                "transition_id": {

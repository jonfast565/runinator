{
  "shutdown_timeout_secs": 12,
  "restart_delay_ms": 2000,
  "processes": [
    {
      "name": "broker",
      "command": "./target/debug/runinator-broker",
      "env": {
        "RUNINATOR_BROKER_TRANSPORT": "tcp",
        "RUNINATOR_BROKER_ADDR": "127.0.0.1:7070"
      }
    },
    {
      "name": "web-service",
      "command": "bash",
      "env": {
        "RUNINATOR_AUTH_BOOTSTRAP_ADMIN": "admin:admin"
      },
      "args": [
        "scripts/start-local-web-service.sh",
        "--port",
        "8080",
        "--gossip-bind",
        "127.0.0.1",
        "--gossip-port",
        "5510",
        "--gossip-targets",
        "127.0.0.1:5511,127.0.0.1:5512,127.0.0.1:5513",
        "--announce-address",
        "127.0.0.1",
        "--announce-base-path",
        "/",
        "--advertise-host",
        "127.0.0.1",
        "--broker-backend",
        "tcp",
        "--broker-endpoint",
        "127.0.0.1:7070"
      ]
    },
    {
      "name": "waker",
      "command": "./target/debug/runinator-waker",
      "args": [
        "--waker-id",
        "runinator-waker-local",
        "--broker-backend",
        "tcp",
        "--broker-endpoint",
        "127.0.0.1:7070",
        "--api-base-url",
        "http://127.0.0.1:8080/",
        "--advertise-host",
        "127.0.0.1"
      ]
    },
    {
      "name": "worker",
      "command": "./target/debug/runinator-worker",
      "args": [
        "--worker-id",
        "runinator-worker-local",
        "--advertise-host",
        "127.0.0.1",
        "--broker-backend",
        "tcp",
        "--broker-endpoint",
        "127.0.0.1:7070",
        "--max-concurrent-actions",
        "4",
        "--api-base-url",
        "http://127.0.0.1:8080/"
      ]
    },
    {
      "name": "pack-import",
      "command": "./target/debug/runinatorctl",
      "args": [
        "--api-base-url",
        "http://127.0.0.1:8080/",
        "workflows",
        "apply",
        "./packs/sdlc/sdlc.wdlp"
      ],
      "restart_on_failure": false
    }
  ]
}

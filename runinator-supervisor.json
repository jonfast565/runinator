{
  "shutdown_timeout_secs": 12,
  "restart_delay_ms": 2000,
  "processes": [
    {
      "name": "broker",
      "command": "./target/debug/runinator-broker",
      "env": {
        "RUNINATOR_BROKER_TRANSPORT": "tcp",
        "RUNINATOR_BROKER_ADDR": "127.0.0.1:7070"
      }
    },
    {
      "name": "web-service",
      "command": "bash",
      "command_windows": "pwsh",
      "env": {
        "RUNINATOR_AUTH_BOOTSTRAP_ADMIN": "admin:admin",
        "RUNINATOR_AUTH_BOOTSTRAP_SERVICE_API_KEY": "localdev.runinator-local-dev-service-key",
        "RUNINATOR_AUTH_BOOTSTRAP_SERVICE_API_KEY_NAME": "local-supervisor",
        "RUNINATOR_OVERLOAD_PROTECTION_ENABLED": "true",
        "RUNINATOR_MAX_CONCURRENT_REQUESTS": "512",
        "RUNINATOR_REQUEST_TIMEOUT_SECONDS": "30",
        "RUNINATOR_DB_MAX_CONNECTIONS": "20",
        "RUNINATOR_DB_ACQUIRE_TIMEOUT_SECONDS": "30",
        "RUNINATOR_PROVISIONER_SUPERVISOR_ENABLED": "true",
        "RUNINATOR_PROVISIONER_SUPERVISOR_WORKER": "{\"command\":\"./target/debug/runinator-worker\",\"args\":[\"--advertise-host\",\"127.0.0.1\",\"--broker-backend\",\"tcp\",\"--broker-endpoint\",\"127.0.0.1:7070\",\"--max-concurrent-actions\",\"4\",\"--api-base-url\",\"http://127.0.0.1:8080/\"],\"env\":{\"RUNINATOR_API_KEY\":\"localdev.runinator-local-dev-service-key\"}}",
        "RUNINATOR_PROVISIONER_SUPERVISOR_WAKER": "{\"command\":\"./target/debug/runinator-waker\",\"args\":[\"--broker-backend\",\"tcp\",\"--broker-endpoint\",\"127.0.0.1:7070\",\"--api-base-url\",\"http://127.0.0.1:8080/\",\"--advertise-host\",\"127.0.0.1\"],\"env\":{\"RUNINATOR_API_KEY\":\"localdev.runinator-local-dev-service-key\"}}"
      },
      "args": [
        "scripts/start-local-web-service.sh",
        "--port",
        "8080",
        "--gossip-bind",
        "127.0.0.1",
        "--gossip-port",
        "5510",
        "--gossip-targets",
        "127.0.0.1:5511,127.0.0.1:5512,127.0.0.1:5513",
        "--announce-address",
        "127.0.0.1",
        "--announce-base-path",
        "/",
        "--advertise-host",
        "127.0.0.1",
        "--broker-backend",
        "tcp",
        "--broker-endpoint",
        "127.0.0.1:7070"
      ],
      "args_windows": [
        "-NoProfile",
        "-File",
        "scripts/start-local-web-service.ps1",
        "--port",
        "8080",
        "--gossip-bind",
        "127.0.0.1",
        "--gossip-port",
        "5510",
        "--gossip-targets",
        "127.0.0.1:5511,127.0.0.1:5512,127.0.0.1:5513",
        "--announce-address",
        "127.0.0.1",
        "--announce-base-path",
        "/",
        "--advertise-host",
        "127.0.0.1",
        "--broker-backend",
        "tcp",
        "--broker-endpoint",
        "127.0.0.1:7070"
      ]
    },
    {
      "name": "waker",
      "command": "./target/debug/runinator-waker",
      "env": {
        "RUNINATOR_API_KEY": "localdev.runinator-local-dev-service-key",
        "RUNINATOR_API_TIMEOUT_SECONDS": "60",
        "RUNINATOR_API_CONNECT_TIMEOUT_SECONDS": "10"
      },
      "args": [
        "--waker-id",
        "runinator-waker-local",
        "--broker-backend",
        "tcp",
        "--broker-endpoint",
        "127.0.0.1:7070",
        "--api-base-url",
        "http://127.0.0.1:8080/",
        "--advertise-host",
        "127.0.0.1"
      ]
    },
    {
      "name": "worker",
      "command": "./target/debug/runinator-worker",
      "env": {
        "RUNINATOR_API_KEY": "localdev.runinator-local-dev-service-key",
        "RUNINATOR_API_TIMEOUT_SECONDS": "60",
        "RUNINATOR_API_CONNECT_TIMEOUT_SECONDS": "10",
        "RUNINATOR_WORKER_LABELS": "runner=sdlc"
      },
      "args": [
        "--worker-id",
        "runinator-worker-local",
        "--advertise-host",
        "127.0.0.1",
        "--broker-backend",
        "tcp",
        "--broker-endpoint",
        "127.0.0.1:7070",
        "--max-concurrent-actions",
        "4",
        "--api-base-url",
        "http://127.0.0.1:8080/"
      ]
    },
    {
      "name": "pack-import",
      "command": "./target/debug/runinatorctl",
      "env": {
        "RUNINATOR_API_KEY": "localdev.runinator-local-dev-service-key"
      },
      "args": [
        "--api-base-url",
        "http://127.0.0.1:8080/",
        "workflows",
        "apply",
        "./packs/sdlc/sdlc.wdlm"
      ],
      "restart_on_failure": false
    },
    {
      "name": "pack-import-hello-world",
      "command": "./target/debug/runinatorctl",
      "env": {
        "RUNINATOR_API_KEY": "localdev.runinator-local-dev-service-key"
      },
      "args": [
        "--api-base-url",
        "http://127.0.0.1:8080/",
        "workflows",
        "apply",
        "./packs/hello-world/hello-world.wdlm"
      ],
      "restart_on_failure": false
    },
    {
      "name": "pack-import-creds-sync",
      "command": "./target/debug/runinatorctl",
      "env": {
        "RUNINATOR_API_KEY": "localdev.runinator-local-dev-service-key"
      },
      "args": [
        "--api-base-url",
        "http://127.0.0.1:8080/",
        "workflows",
        "apply",
        "packs/creds-sync/creds-sync.wdlm"
      ],
      "restart_on_failure": false
    }
  ]
}

{
  "shutdown_timeout_secs": 12,
  "restart_delay_ms": 2000,
  "processes": [
    {
      "name": "broker",
      "command": "./target/debug/runinator-broker",
      "env": {
        "RUNINATOR_BROKER_TRANSPORT": "tcp",
        "RUNINATOR_BROKER_ADDR": "127.0.0.1:7070"
      }
    },
    {
      "name": "web-service",
      "command": "./target/debug/runinator-ws",
      "args": [
        "--database",
        "sqlite",
        "--port",
        "8080",
        "--gossip-bind",
        "127.0.0.1",
        "--gossip-port",
        "5510",
        "--gossip-targets",
        "127.0.0.1:5511,127.0.0.1:5512,127.0.0.1:5513",
        "--announce-address",
        "127.0.0.1",
        "--announce-base-path",
        "/",
        "--broker-backend",
        "tcp",
        "--broker-endpoint",
        "127.0.0.1:7070"
      ]
    },
    {
      "name": "scheduler",
      "command": "./target/debug/runinator-scheduler",
      "args": [
        "--scheduler-frequency-seconds",
        "1",
        "--gossip-bind",
        "127.0.0.1",
        "--gossip-port",
        "5511",
        "--gossip-targets",
        "127.0.0.1:5510,127.0.0.1:5512",
        "--api-timeout-seconds",
        "30",
        "--broker-backend",
        "tcp",
        "--broker-endpoint",
        "127.0.0.1:7070"
      ]
    },
    {
      "name": "worker",
      "command": "./target/debug/runinator-worker",
      "args": [
        "--broker-backend",
        "tcp",
        "--broker-endpoint",
        "127.0.0.1:7070",
        "--max-concurrent-actions",
        "4",
        "--api-base-url",
        "http://127.0.0.1:8080/"
      ]
    },
    {
      "name": "importer",
      "command": "./target/debug/runinator-importer",
      "args": [
        "--once",
        "--workflows-file",
        "./packs/sdlc/workflow-pack.json",
        "--gossip-bind",
        "127.0.0.1",
        "--gossip-port",
        "5512",
        "--gossip-targets",
        "127.0.0.1:5510,127.0.0.1:5511"
      ],
      "restart_on_failure": false
    }
  ]
}
